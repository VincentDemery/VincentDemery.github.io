@article{Demery2026Effects,
  title = {Effect of solvent structure on the {{Wien}} effect and ionic correlations at the nanoscale},
  author = {Démery, Vincent and Toquer, Damien and Berthoumieux, Hélène},
  year = 2026,
  journal = {Faraday Discussions},
  pages = {10.1039.D5FD00149H},
  issn = {1359-6640, 1364-5498},
  doi = {10.1039/D5FD00149H},
  urldate = {2026-05-07},
  abstract = {In this study, we examine how the structure of the solvent affects the correlations and conductivity of moderately concentrated electrolytes. We describe polar solvents with a nonlocal permittivity, ε(k), which we then incorporate into stochastic density functional theory (SDFT), focusing on ion transport in water. Using nonlocal SDFT and classical molecular dynamics simulations, we study the ionic hydration shell and its deformation under an electrostatic field. This allows us to identify the minimal ingredients required for an implicit solvent description to reproduce simulation results. As a perspective, we apply this framework to the transport of ions in a two-dimensional slab.},
  langid = {english}
}
